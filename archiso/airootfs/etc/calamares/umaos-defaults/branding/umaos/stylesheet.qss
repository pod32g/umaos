/* UmaOS Calamares Stylesheet — Dark Emerald Theme
   Matches the GRUB / KSplash / SDDM dark green branding.
   Sidebar colors come from branding.desc and override these. */


/* ══════════════════════════════════════════════════════════
   Base dark theme — applies to the entire main content area
   ══════════════════════════════════════════════════════════ */

QWidget {
    background-color: #162b1c;
    color: #dce8de;
    font-family: "Noto Sans", "Segoe UI", sans-serif;
}

QMainWindow, #mainApp {
    background-color: #0e1f14;
}

/* The main stacked content pages */
QStackedWidget {
    background-color: #162b1c;
}


/* ══════════════════════════════════════════════════════════
   Typography
   ══════════════════════════════════════════════════════════ */

QLabel {
    background-color: transparent;
    color: #dce8de;
}

/* Subdued/secondary text */
QLabel[objectName="comment"],
QLabel[objectName="description"] {
    color: #8ab892;
}

/* Heading labels (Welcome title etc.) */
QLabel#mainText, QLabel#heading {
    color: #ffffff;
    font-size: 18px;
    font-weight: bold;
}


/* ══════════════════════════════════════════════════════════
   Navigation buttons
   ══════════════════════════════════════════════════════════ */

/* "Next" / primary action */
#next_button {
    background-color: #42a54b;
    color: #ffffff;
    border: none;
    padding: 8px 24px;
    border-radius: 4px;
    font-weight: bold;
    min-width: 80px;
}
#next_button:hover {
    background-color: #4db856;
}
#next_button:pressed {
    background-color: #2e8838;
}

/* "Back" — outlined style */
#back_button {
    background-color: transparent;
    color: #42a54b;
    border: 1px solid #42a54b;
    padding: 8px 24px;
    border-radius: 4px;
    min-width: 80px;
}
#back_button:hover {
    background-color: rgba(66, 165, 75, 0.12);
}

/* "Cancel" */
#cancel_button {
    background-color: transparent;
    color: #8ab892;
    border: 1px solid #2a5a32;
    padding: 8px 24px;
    border-radius: 4px;
    min-width: 80px;
}
#cancel_button:hover {
    background-color: rgba(66, 165, 75, 0.08);
    color: #dce8de;
}

/* "Done" / "Restart" on the finish page */
#quit_button {
    background-color: #42a54b;
    color: #ffffff;
    border: none;
    padding: 8px 24px;
    border-radius: 4px;
    font-weight: bold;
    min-width: 80px;
}
#quit_button:hover {
    background-color: #4db856;
}


/* ══════════════════════════════════════════════════════════
   Form inputs
   ══════════════════════════════════════════════════════════ */

QLineEdit {
    background-color: #0e1f14;
    color: #dce8de;
    border: 1px solid #2a5a32;
    border-radius: 4px;
    padding: 6px 10px;
    selection-background-color: #42a54b;
    selection-color: #ffffff;
}
QLineEdit:focus {
    border-color: #42a54b;
}
QLineEdit:disabled {
    background-color: #1a2e1f;
    color: #5a7a62;
}

QTextEdit, QPlainTextEdit {
    background-color: #0e1f14;
    color: #dce8de;
    border: 1px solid #2a5a32;
    border-radius: 4px;
    padding: 4px;
    selection-background-color: #42a54b;
}

QSpinBox {
    background-color: #0e1f14;
    color: #dce8de;
    border: 1px solid #2a5a32;
    border-radius: 4px;
    padding: 4px 8px;
}
QSpinBox:focus {
    border-color: #42a54b;
}


/* ══════════════════════════════════════════════════════════
   Dropdowns / combo boxes
   ══════════════════════════════════════════════════════════ */

QComboBox {
    background-color: #0e1f14;
    color: #dce8de;
    border: 1px solid #2a5a32;
    border-radius: 4px;
    padding: 6px 10px;
    min-height: 20px;
}
QComboBox:focus, QComboBox:on {
    border-color: #42a54b;
}
QComboBox::drop-down {
    border: none;
    width: 24px;
}
QComboBox::down-arrow {
    image: none;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 6px solid #8ab892;
    margin-right: 8px;
}
QComboBox QAbstractItemView {
    background-color: #0e1f14;
    color: #dce8de;
    border: 1px solid #2a5a32;
    selection-background-color: #42a54b;
    selection-color: #ffffff;
    outline: none;
}


/* ══════════════════════════════════════════════════════════
   Checkboxes & radio buttons
   ══════════════════════════════════════════════════════════ */

QCheckBox, QRadioButton {
    color: #dce8de;
    spacing: 8px;
}

QCheckBox::indicator, QRadioButton::indicator {
    width: 16px;
    height: 16px;
    border: 2px solid #2a5a32;
    border-radius: 3px;
    background-color: #0e1f14;
}
QRadioButton::indicator {
    border-radius: 10px;
}

QCheckBox::indicator:checked, QRadioButton::indicator:checked {
    background-color: #42a54b;
    border-color: #42a54b;
}

QCheckBox::indicator:hover, QRadioButton::indicator:hover {
    border-color: #42a54b;
}


/* ══════════════════════════════════════════════════════════
   Progress bar
   ══════════════════════════════════════════════════════════ */

QProgressBar {
    background-color: #0e1f14;
    border: 1px solid #2a5a32;
    border-radius: 3px;
    height: 8px;
    text-align: center;
    color: transparent;
}
QProgressBar::chunk {
    background-color: #42a54b;
    border-radius: 3px;
}


/* ══════════════════════════════════════════════════════════
   Group boxes & frames
   ══════════════════════════════════════════════════════════ */

QGroupBox {
    background-color: #1a2e1f;
    border: 1px solid #2a5a32;
    border-radius: 6px;
    margin-top: 16px;
    padding-top: 20px;
    color: #dce8de;
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 4px 12px;
    color: #8ab892;
    font-weight: bold;
}

QFrame[frameShape="4"],   /* HLine */
QFrame[frameShape="5"] {  /* VLine */
    color: #2a5a32;
    background-color: #2a5a32;
    max-height: 1px;
}


/* ══════════════════════════════════════════════════════════
   Lists, trees, and tables (partition editor, etc.)
   ══════════════════════════════════════════════════════════ */

QListView, QTreeView, QTableView {
    background-color: #0e1f14;
    color: #dce8de;
    border: 1px solid #2a5a32;
    border-radius: 4px;
    outline: none;
    alternate-background-color: #142618;
}
QListView::item, QTreeView::item, QTableView::item {
    padding: 4px;
}
QListView::item:selected, QTreeView::item:selected, QTableView::item:selected {
    background-color: #42a54b;
    color: #ffffff;
}
QListView::item:hover, QTreeView::item:hover, QTableView::item:hover {
    background-color: #1a3d24;
}

QHeaderView::section {
    background-color: #1a2e1f;
    color: #8ab892;
    border: none;
    border-bottom: 1px solid #2a5a32;
    padding: 6px;
    font-weight: bold;
}


/* ══════════════════════════════════════════════════════════
   Scroll bars
   ══════════════════════════════════════════════════════════ */

QScrollBar:vertical {
    background-color: #0e1f14;
    width: 10px;
    border: none;
}
QScrollBar::handle:vertical {
    background-color: #2a5a32;
    border-radius: 5px;
    min-height: 30px;
}
QScrollBar::handle:vertical:hover {
    background-color: #42a54b;
}
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0px;
}

QScrollBar:horizontal {
    background-color: #0e1f14;
    height: 10px;
    border: none;
}
QScrollBar::handle:horizontal {
    background-color: #2a5a32;
    border-radius: 5px;
    min-width: 30px;
}
QScrollBar::handle:horizontal:hover {
    background-color: #42a54b;
}
QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    width: 0px;
}

QScrollArea {
    background-color: transparent;
    border: none;
}


/* ══════════════════════════════════════════════════════════
   Tabs (used by some Calamares modules)
   ══════════════════════════════════════════════════════════ */

QTabWidget::pane {
    background-color: #162b1c;
    border: 1px solid #2a5a32;
    border-radius: 4px;
}
QTabBar::tab {
    background-color: #0e1f14;
    color: #8ab892;
    border: 1px solid #2a5a32;
    padding: 8px 16px;
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
}
QTabBar::tab:selected {
    background-color: #162b1c;
    color: #dce8de;
    border-bottom-color: #162b1c;
}
QTabBar::tab:hover:!selected {
    background-color: #1a3d24;
}


/* ══════════════════════════════════════════════════════════
   Generic push buttons (not nav buttons)
   ══════════════════════════════════════════════════════════ */

QPushButton {
    background-color: #1a3d24;
    color: #dce8de;
    border: 1px solid #2a5a32;
    border-radius: 4px;
    padding: 6px 16px;
    min-width: 60px;
}
QPushButton:hover {
    background-color: #245832;
    border-color: #42a54b;
}
QPushButton:pressed {
    background-color: #42a54b;
    color: #ffffff;
}
QPushButton:disabled {
    background-color: #142618;
    color: #4a6a52;
    border-color: #1a3d24;
}


/* ══════════════════════════════════════════════════════════
   Tooltips
   ══════════════════════════════════════════════════════════ */

QToolTip {
    background-color: #1a3d24;
    color: #dce8de;
    border: 1px solid #42a54b;
    border-radius: 4px;
    padding: 4px 8px;
}


/* ══════════════════════════════════════════════════════════
   Links
   ══════════════════════════════════════════════════════════ */

QLabel a, a {
    color: #42a54b;
}
