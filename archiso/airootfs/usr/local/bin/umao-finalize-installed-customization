#!/usr/bin/env bash
set -euo pipefail

log() {
  printf '[umao-finalize-installed-customization] %s\n' "$*"
}

trim() {
  local v="$1"
  v="${v#"${v%%[![:space:]]*}"}"
  v="${v%"${v##*[![:space:]]}"}"
  printf '%s\n' "$v"
}

ensure_graphical_boot() {
  # systemctl is unavailable inside the Calamares chroot (systemd is not PID 1).
  # Create the symlinks manually instead of using systemctl enable.
  install -d /etc/systemd/system
  ln -sfn /usr/lib/systemd/system/graphical.target /etc/systemd/system/default.target

  install -d /etc/systemd/system/graphical.target.wants
  ln -sfn /usr/lib/systemd/system/sddm.service /etc/systemd/system/graphical.target.wants/sddm.service
  ln -sfn /usr/lib/systemd/system/sddm.service /etc/systemd/system/display-manager.service
}

write_installed_motd() {
  cat > /etc/motd <<'EOF'
Welcome to UmaOS

Quick start:
  1) Refresh scripts from GitHub: sudo uma-update
  2) Reapply desktop defaults: umao-apply-theme --once
  3) Driver auto-detect and install: sudo umao-driver-setup --yes
  4) Audio diagnostics: umao-audio-doctor
  5) Install game from desktop: Install Uma Musume.sh

Project: UmaOS
EOF
}

resolve_cursor_theme() {
  local preferred="pixloen-haru-urara-v1.7"
  if [[ -d "/usr/share/icons/$preferred" ]]; then
    printf '%s\n' "$preferred"
    return 0
  fi
  printf '%s\n' "breeze_cursors"
}

write_system_theme_defaults() {
  local cursor_theme="$1"
  local sddm_theme="umaos-race"

  # Keep UmaOS branding by default, but never brick login if the theme is missing.
  if [[ ! -f "/usr/share/sddm/themes/${sddm_theme}/Main.qml" ]]; then
    sddm_theme="breeze"
  fi

  install -d /etc/sddm.conf.d
  cat > /etc/sddm.conf.d/umaos-theme.conf <<'EOF'
[Theme]
Current=__SDDM_THEME__
CursorTheme=__CURSOR_THEME__
CursorSize=24
EOF
  sed -i "s/__SDDM_THEME__/${sddm_theme}/g" /etc/sddm.conf.d/umaos-theme.conf
  sed -i "s/__CURSOR_THEME__/${cursor_theme}/g" /etc/sddm.conf.d/umaos-theme.conf

  # Pin SDDM to X11: the Wayland SDDM greeter is unstable in VMs (black screen
  # on VirtIO/QXL), and NVIDIA proprietary drivers sometimes fail at login.
  cat > /etc/sddm.conf.d/10-umaos-display.conf <<'EOF'
[General]
DisplayServer=x11
EOF

  # Live-only SDDM autologin config should never survive installation.
  rm -f /etc/sddm.conf.d/umaos-live.conf

  install -d /etc/xdg

  cat > /etc/xdg/mimeapps.list <<'EOF'
[Default Applications]
x-scheme-handler/http=helium.desktop
x-scheme-handler/https=helium.desktop
x-scheme-handler/about=helium.desktop
x-scheme-handler/unknown=helium.desktop
text/html=helium.desktop
application/xhtml+xml=helium.desktop
application/x-extension-htm=helium.desktop
application/x-extension-html=helium.desktop
application/x-extension-shtml=helium.desktop
application/x-extension-xhtml=helium.desktop
application/x-extension-xht=helium.desktop
EOF

  cat > /etc/xdg/konsolerc <<'EOF'
[Desktop Entry]
DefaultProfile=UmaOS.profile
EOF

  # Write full color values so KDE picks up the theme without needing
  # plasma-apply-colorscheme at first login.
  if [[ -f /usr/share/color-schemes/UmaSkyPink.colors ]]; then
    cp /usr/share/color-schemes/UmaSkyPink.colors /etc/xdg/kdeglobals
    # Append the keys that are not part of the .colors file
    cat >> /etc/xdg/kdeglobals <<'EOF'

[Icons]
Theme=UmaOS-Papirus

[KDE]
widgetStyle=Breeze
EOF
  else
    cat > /etc/xdg/kdeglobals <<'EOF'
[General]
ColorScheme=UmaSkyPink

[Icons]
Theme=UmaOS-Papirus

[KDE]
widgetStyle=Breeze
EOF
  fi

  cat > /etc/xdg/kcminputrc <<'EOF'
[Mouse]
cursorTheme=__CURSOR_THEME__
cursorThemeName=__CURSOR_THEME__
cursorSize=24
EOF
  sed -i "s/__CURSOR_THEME__/${cursor_theme}/g" /etc/xdg/kcminputrc

  install -d /usr/share/icons/default
  cat > /usr/share/icons/default/index.theme <<'EOF'
[Icon Theme]
Inherits=__CURSOR_THEME__
EOF
  sed -i "s/__CURSOR_THEME__/${cursor_theme}/g" /usr/share/icons/default/index.theme
}

sanitize_sddm_configuration() {
  local sddm_cfg="/etc/sddm.conf"
  [[ -f "$sddm_cfg" ]] || return 0

  # Calamares may emit session aliases that are not valid .desktop entries.
  sed -i \
    -e 's/^Session=plasma$/Session=plasma.desktop/' \
    -e 's/^Session=plasma-x11$/Session=plasma.desktop/' \
    -e 's/^Session=plasmawayland$/Session=plasmawayland.desktop/' \
    "$sddm_cfg"

  # If Autologin exists but has no user, drop the generated file entirely.
  if awk '
    /^\[Autologin\]$/ { in_auto=1; saw_auto=1; next }
    /^\[/ { in_auto=0 }
    in_auto && /^User=/ { has_user=1 }
    END { exit !(saw_auto && !has_user) }
  ' "$sddm_cfg"; then
    log "Removing invalid ${sddm_cfg} (Autologin without User=)."
    rm -f "$sddm_cfg"
  fi
}

ensure_admin_privileges() {
  local user_name="$1"

  if ! getent group wheel >/dev/null 2>&1; then
    groupadd wheel
  fi

  # Ensure wheel can sudo in installed systems even if Calamares sudoers setup was skipped.
  install -d /etc/sudoers.d
  cat > /etc/sudoers.d/10-umaos-wheel <<'EOF'
%wheel ALL=(ALL:ALL) ALL
EOF
  chmod 0440 /etc/sudoers.d/10-umaos-wheel

  if id -nG "$user_name" 2>/dev/null | tr ' ' '\n' | grep -qx wheel; then
    return 0
  fi

  usermod -aG wheel "$user_name"
  log "Added user '$user_name' to wheel for sudo access."
}

ensure_wallpaper_metadata_json() {
  local wallpapers_root="/usr/share/wallpapers"
  local dir
  local id
  local desktop
  local json
  local name
  local generated=0

  [[ -d "$wallpapers_root" ]] || return 0

  for dir in "$wallpapers_root"/*; do
    [[ -d "$dir" ]] || continue
    desktop="$dir/metadata.desktop"
    json="$dir/metadata.json"
    [[ -f "$desktop" ]] || continue
    [[ -f "$json" ]] && continue

    id="$(basename "$dir")"
    name="$(awk -F= '
      /^\[Desktop Entry\]$/ { in_desktop=1; next }
      /^\[/ { if (in_desktop) in_desktop=0 }
      in_desktop && /^Name=/ { print substr($0,6); exit }
    ' "$desktop" | head -n1)"
    name="$(trim "${name:-}")"
    [[ -n "$name" ]] || name="$id"

    cat > "$json" <<EOF
{
  "KPlugin": {
    "Id": "$id",
    "Name": "$name",
    "Description": "$name wallpaper",
    "License": "Unknown"
  }
}
EOF
    generated=$((generated + 1))
  done

  if ((generated > 0)); then
    log "Generated missing Plasma metadata.json for ${generated} wallpaper package(s)."
  fi
}

sync_user_customization() {
  local user_name="$1"
  local user_home="$2"
  local uid="$3"
  local gid="$4"
  local cursor_theme="$5"

  [[ -d "$user_home" ]] || return 0

  install -d -m 700 -o "$uid" -g "$gid" "$user_home/.config"
  install -d -m 700 -o "$uid" -g "$gid" "$user_home/.config/umaos"
  install -d -m 755 -o "$uid" -g "$gid" "$user_home/Desktop"
  install -d -m 700 -o "$uid" -g "$gid" "$user_home/.icons/default"

  local src
  for src in kdeglobals kcminputrc ksplashrc kscreenlockerrc kwinrc konsolerc mimeapps.list plasma-org.kde.plasma.desktop-appletsrc plasmashellrc; do
    if [[ -f "/etc/skel/.config/$src" ]]; then
      install -m 600 -o "$uid" -g "$gid" "/etc/skel/.config/$src" "$user_home/.config/$src"
    else
      log "WARNING: Missing /etc/skel/.config/$src for user '$user_name'"
    fi
  done

  install -d -m 700 -o "$uid" -g "$gid" "$user_home/.config/autostart"
  for src in umaos-first-login.desktop umao-umamusume-first-login.desktop; do
    if [[ -f "/etc/skel/.config/autostart/$src" ]]; then
      install -m 644 -o "$uid" -g "$gid" "/etc/skel/.config/autostart/$src" \
        "$user_home/.config/autostart/$src"
    else
      log "WARNING: Missing /etc/skel/.config/autostart/$src for user '$user_name'"
    fi
  done

  if [[ -f "/etc/skel/Desktop/Install Uma Musume.sh" ]]; then
    install -m 755 -o "$uid" -g "$gid" "/etc/skel/Desktop/Install Uma Musume.sh" \
      "$user_home/Desktop/Install Uma Musume.sh"
  else
    log "WARNING: Missing /etc/skel/Desktop/Install Uma Musume.sh for user '$user_name'"
  fi

  # Sync desktop utility launchers.
  for src in "UmaOS Update.desktop" "Driver Setup.desktop" "Audio Doctor.desktop"; do
    if [[ -f "/etc/skel/Desktop/$src" ]]; then
      install -m 755 -o "$uid" -g "$gid" "/etc/skel/Desktop/$src" \
        "$user_home/Desktop/$src"
    fi
  done

  # Sync GTK theme settings.
  for gtk_ver in gtk-3.0 gtk-4.0; do
    if [[ -f "/etc/skel/.config/$gtk_ver/settings.ini" ]]; then
      install -d -m 700 -o "$uid" -g "$gid" "$user_home/.config/$gtk_ver"
      install -m 600 -o "$uid" -g "$gid" "/etc/skel/.config/$gtk_ver/settings.ini" \
        "$user_home/.config/$gtk_ver/settings.ini"
    fi
  done

  # Sync fastfetch config.
  if [[ -f "/etc/skel/.config/fastfetch/config.jsonc" ]]; then
    install -d -m 700 -o "$uid" -g "$gid" "$user_home/.config/fastfetch"
    install -m 600 -o "$uid" -g "$gid" "/etc/skel/.config/fastfetch/config.jsonc" \
      "$user_home/.config/fastfetch/config.jsonc"
  fi

  cat > "$user_home/.icons/default/index.theme" <<'EOF'
[Icon Theme]
Inherits=__CURSOR_THEME__
EOF
  sed -i "s/__CURSOR_THEME__/${cursor_theme}/g" "$user_home/.icons/default/index.theme"
  chown "$uid:$gid" "$user_home/.icons/default/index.theme"

  # Ensure first login retries full theme application and video wallpaper setup.
  rm -f \
    "$user_home/.config/umaos/theme-applied" \
    "$user_home/.config/umaos/video-wallpaper.disabled" \
    "$user_home/.config/umaos/video-wallpaper.failcount"
  chown "$uid:$gid" "$user_home/.config/umaos"
}

main() {
  local cursor_theme
  cursor_theme="$(resolve_cursor_theme)"
  ensure_graphical_boot
  write_system_theme_defaults "$cursor_theme"
  ensure_wallpaper_metadata_json
  sanitize_sddm_configuration
  write_installed_motd

  if command -v umao-refresh-lsb-release >/dev/null 2>&1; then
    if ! umao-refresh-lsb-release; then
      log "WARNING: Failed to refresh lsb-release branding."
    fi
  fi

  while IFS=: read -r name _ uid gid _ home shell; do
    [[ "$uid" =~ ^[0-9]+$ ]] || continue
    (( uid >= 1000 && uid < 60000 )) || continue
    [[ "$home" != "/" && -n "$home" ]] || continue
    [[ "$shell" != "/usr/bin/nologin" && "$shell" != "/bin/false" ]] || continue
    ensure_admin_privileges "$name"
    sync_user_customization "$name" "$home" "$uid" "$gid" "$cursor_theme"
    log "Applied UmaOS customization for user '$name'."
  done < /etc/passwd

  # Set UmaOS Plymouth theme on installed system.
  if command -v plymouth-set-default-theme >/dev/null 2>&1; then
    if [[ -f /usr/share/plymouth/themes/umaos/umaos.plymouth ]]; then
      plymouth-set-default-theme umaos
      log "Plymouth default theme set to umaos."
    fi
  fi

  install -d /var/lib/umaos
  date -Iseconds > /var/lib/umaos/install-customization.done
  echo "Umazing!"
}

main "$@"
