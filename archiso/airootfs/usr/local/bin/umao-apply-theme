#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: umao-apply-theme [--once] [--video] [--no-video] [--debug-video]"
}

once=0
force_video=0
disable_video=0
debug_video=0
if (($# > 0)); then
  while (($# > 0)); do
    case "$1" in
      --once)
        once=1
        ;;
      --video)
        force_video=1
        ;;
      --no-video)
        disable_video=1
        ;;
      --debug-video)
        debug_video=1
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        echo "Unknown argument: $1" >&2
        usage >&2
        exit 2
        ;;
    esac
    shift
  done
fi

if [[ -z "${HOME:-}" ]]; then
  echo "HOME is not set." >&2
  exit 1
fi

state_dir="$HOME/.config/umaos"
state_file="$state_dir/theme-applied"
mkdir -p "$state_dir"
log_file="$state_dir/video-wallpaper-debug.log"
video_disabled_marker="$state_dir/video-wallpaper.disabled"
video_fail_file="$state_dir/video-wallpaper.failcount"

if (($once == 1)) && [[ -f "$state_file" ]]; then
  exit 0
fi

wallpaper_video="/usr/share/wallpapers/UmaOS/contents/videos/qloo.mp4"
wallpaper_fallback="/usr/share/wallpapers/UmaOS/contents/images/1920x1080.jpg"
video_plugin_id="luisbocanegra.smart.video.wallpaper.reborn"
video_plugin_dir="/usr/share/plasma/wallpapers/${video_plugin_id}"
cursor_theme="pixloen-haru-urara-v1.7"
wallpaper_applied=0
apply_video=1
video_stability_seconds="${UMAOS_VIDEO_STABILITY_SECONDS:-12}"
has_graphical_session=0
video_fail_count=0
video_apply_failed=0

if [[ -n "${DISPLAY:-}" || -n "${WAYLAND_DISPLAY:-}" ]]; then
  has_graphical_session=1
fi

if [[ -f "$video_fail_file" ]]; then
  read -r video_fail_count < "$video_fail_file" || true
  [[ "$video_fail_count" =~ ^[0-9]+$ ]] || video_fail_count=0
fi

if [[ "${UMAOS_VIDEO_WALLPAPER:-1}" == "0" ]] || ((disable_video == 1)); then
  apply_video=0
fi
if ((force_video == 1)) || [[ "${UMAOS_VIDEO_WALLPAPER:-1}" == "1" ]]; then
  apply_video=1
fi
if [[ "${UMAOS_DEBUG_VIDEO_WALLPAPER:-0}" == "1" ]]; then
  debug_video=1
fi
if ((force_video == 0)) && [[ -f "$video_disabled_marker" ]]; then
  # Backward-compatible self-heal:
  # Older builds created the disable marker without a failcount.
  # Re-enable video automatically unless we have reached the hard failure threshold.
  if ((video_fail_count >= 3)); then
    apply_video=0
  else
    rm -f "$video_disabled_marker"
    apply_video=1
    if ((debug_video == 1)); then
      printf '[%s] %s\n' "$(date -Iseconds)" \
        "Cleared stale video disable marker (failcount=${video_fail_count})." >> "$log_file"
    fi
  fi
fi

log_debug() {
  if ((debug_video == 1)); then
    printf '[%s] %s\n' "$(date -Iseconds)" "$*" >> "$log_file"
  fi
}

capture_recent_logs() {
  if ((debug_video == 1)); then
    {
      echo "----- user journal (recent) -----"
      journalctl --user -b --since "-3 min" --no-pager
      echo "----- system journal (recent) -----"
      journalctl -b --since "-3 min" --no-pager
    } >> "$log_file" 2>/dev/null || true
  fi
}

clear_video_urls_config() {
  local cfg
  for cfg in \
    "$HOME/.config/plasma-org.kde.plasma.desktop-appletsrc" \
    "$HOME/.config/kscreenlockerrc"; do
    [[ -f "$cfg" ]] || continue
    sed -i 's/^VideoUrls=.*$/VideoUrls=/g' "$cfg" || true
  done
}

find_qdbus_cmd() {
  local candidate
  for candidate in qdbus6 qdbus-qt6 qdbus; do
    if command -v "$candidate" >/dev/null 2>&1; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
  return 1
}

apply_video_wallpaper_plugin() {
  local qdbus_cmd="$1"
  local video_uri="file://${wallpaper_video}"
  local js

  js="$(cat <<EOF
var allDesktops = desktops();
for (var i = 0; i < allDesktops.length; i++) {
  var d = allDesktops[i];
  d.wallpaperPlugin = "${video_plugin_id}";
  d.currentConfigGroup = ["Wallpaper", "${video_plugin_id}", "General"];
  d.writeConfig("VideoUrls", JSON.stringify([{ filename: "${video_uri}", enabled: true }]));
  d.writeConfig("ResumeLastVideo", true);
  d.writeConfig("RandomMode", false);
  d.reloadConfig();
}
EOF
)"

  "$qdbus_cmd" org.kde.plasmashell /PlasmaShell org.kde.PlasmaShell.evaluateScript "$js" >/dev/null 2>&1
}

if ((has_graphical_session == 1)) && command -v plasma-apply-colorscheme >/dev/null 2>&1; then
  if ! plasma-apply-colorscheme UmaSkyPink >/dev/null 2>&1; then
    log_debug "WARNING: Failed to apply UmaSkyPink color scheme."
  fi
fi

if ((has_graphical_session == 1)) && ((apply_video == 1)) && [[ -f "$wallpaper_video" ]] && [[ -d "$video_plugin_dir" ]]; then
  qdbus_cmd="$(find_qdbus_cmd || true)"
  old_pid="$(pgrep -n -u "$(id -u)" plasmashell 2>/dev/null || true)"
  log_debug "Attempting video wallpaper plugin apply: $wallpaper_video via ${qdbus_cmd:-none} (old plasmashell pid: ${old_pid:-none})"

  if [[ -n "$qdbus_cmd" ]] && apply_video_wallpaper_plugin "$qdbus_cmd"; then
    local_pid="$(pgrep -n -u "$(id -u)" plasmashell 2>/dev/null || true)"
    restarted=0
    log_debug "Video wallpaper plugin apply returned success (pid: ${local_pid:-none}); monitoring ${video_stability_seconds}s."

    if [[ -z "${local_pid:-}" ]]; then
      restarted=1
    else
      for ((i = 0; i < video_stability_seconds; i++)); do
        sleep 1
        new_pid="$(pgrep -n -u "$(id -u)" plasmashell 2>/dev/null || true)"
        if [[ -z "${new_pid:-}" || "$new_pid" != "$local_pid" ]]; then
          restarted=1
          break
        fi
      done
    fi

    if ((restarted == 1)); then
      log_debug "plasmashell crashed/restarted after video wallpaper apply; recording failure."
      video_apply_failed=1
      video_fail_count=$((video_fail_count + 1))
      printf '%s\n' "$video_fail_count" > "$video_fail_file"
      if ((video_fail_count >= 3)); then
        touch "$video_disabled_marker"
      else
        rm -f "$video_disabled_marker"
      fi
      clear_video_urls_config
      capture_recent_logs
    else
      wallpaper_applied=1
      video_fail_count=0
      rm -f "$video_fail_file"
      rm -f "$video_disabled_marker"
    fi
  else
    log_debug "Video wallpaper plugin apply failed (plugin or qdbus missing); using fallback wallpaper."
    video_apply_failed=1
    video_fail_count=$((video_fail_count + 1))
    printf '%s\n' "$video_fail_count" > "$video_fail_file"
    if ((video_fail_count >= 3)); then
      touch "$video_disabled_marker"
    else
      rm -f "$video_disabled_marker"
    fi
    capture_recent_logs
  fi
fi

if ((has_graphical_session == 1)) && command -v plasma-apply-wallpaperimage >/dev/null 2>&1; then
  if [[ "$wallpaper_applied" -eq 0 ]] && [[ -f "$wallpaper_fallback" ]]; then
    if ! plasma-apply-wallpaperimage "$wallpaper_fallback" >/dev/null 2>&1; then
      log_debug "WARNING: Failed to apply fallback wallpaper."
    fi
  fi
fi

kwriteconfig_cmd=""
if command -v kwriteconfig6 >/dev/null 2>&1; then
  kwriteconfig_cmd="kwriteconfig6"
elif command -v kwriteconfig5 >/dev/null 2>&1; then
  kwriteconfig_cmd="kwriteconfig5"
fi

if [[ -n "$kwriteconfig_cmd" ]]; then
  if [[ ! -d "/usr/share/icons/${cursor_theme}" ]]; then
    cursor_theme="breeze_cursors"
  fi
  "$kwriteconfig_cmd" --file kdeglobals --group General --key ColorScheme UmaSkyPink
  "$kwriteconfig_cmd" --file kdeglobals --group Icons --key Theme UmaOS-Papirus
  "$kwriteconfig_cmd" --file kdeglobals --group KDE --key widgetStyle Breeze
  "$kwriteconfig_cmd" --file kdeglobals --group KDE --key LookAndFeelPackage com.umaos.desktop
  "$kwriteconfig_cmd" --file ksplashrc --group KSplash --key Theme com.umaos.desktop
  "$kwriteconfig_cmd" --file kcminputrc --group Mouse --key cursorTheme "$cursor_theme"
  "$kwriteconfig_cmd" --file kcminputrc --group Mouse --key cursorThemeName "$cursor_theme"
  mkdir -p "$HOME/.icons/default"
  cat > "$HOME/.icons/default/index.theme" <<EOF
[Icon Theme]
Inherits=${cursor_theme}
EOF
fi

# ── Panel customization: floating, translucent, and UmaOS launcher icon ──
# Plasma's layout.js sets widget config but cannot set floating (a PanelView
# property in plasmashellrc) or reliably set panelOpacity.  Patch them here
# after Plasma has generated its initial config.
apply_panel_properties() {
  local appletsrc="$HOME/.config/plasma-org.kde.plasma.desktop-appletsrc"
  local shellrc="$HOME/.config/plasmashellrc"
  [[ -f "$appletsrc" ]] || return 0

  # Find the panel containment ID (the one with plugin=org.kde.panel)
  local panel_id=""
  local in_containment=""
  while IFS= read -r line; do
    if [[ "$line" =~ ^\[Containments\]\[([0-9]+)\]$ ]]; then
      in_containment="${BASH_REMATCH[1]}"
    elif [[ -n "$in_containment" && "$line" == "plugin=org.kde.panel" ]]; then
      panel_id="$in_containment"
      break
    elif [[ "$line" =~ ^\[ ]]; then
      in_containment=""
    fi
  done < "$appletsrc"

  [[ -n "$panel_id" ]] || return 0

  # Set panelOpacity=2 (translucent) in the containment's [General] group
  if ! grep -q "^\[Containments\]\[${panel_id}\]\[General\]" "$appletsrc" 2>/dev/null; then
    printf '\n[Containments][%s][General]\npanelOpacity=2\n' "$panel_id" >> "$appletsrc"
  elif ! grep -q '^panelOpacity=' <(sed -n "/^\[Containments\]\[${panel_id}\]\[General\]/,/^\[/p" "$appletsrc"); then
    sed -i "/^\[Containments\]\[${panel_id}\]\[General\]/a panelOpacity=2" "$appletsrc"
  fi

  # Set floating=1 in plasmashellrc [PlasmaViews][Panel <id>]
  local panel_section="PlasmaViews][Panel ${panel_id}"
  if [[ -f "$shellrc" ]]; then
    if ! grep -q "^\[${panel_section}\]" "$shellrc" 2>/dev/null; then
      printf '\n[%s]\nfloating=1\nThickness=44\n' "$panel_section" >> "$shellrc"
    elif ! grep -q '^floating=' <(sed -n "/^\[${panel_section}\]/,/^\[/p" "$shellrc"); then
      sed -i "/^\[${panel_section}\]/a floating=1" "$shellrc"
    fi
  else
    printf '[%s]\nfloating=1\nThickness=44\n' "$panel_section" > "$shellrc"
  fi

  # Ensure the Kickoff applet uses our custom icon
  local kickoff_section=""
  local in_section=""
  while IFS= read -r line; do
    if [[ "$line" =~ ^\[Containments\]\[${panel_id}\]\[Applets\]\[([0-9]+)\]$ ]]; then
      in_section="${BASH_REMATCH[0]}"
    elif [[ -n "$in_section" && "$line" == "plugin=org.kde.plasma.kickoff" ]]; then
      kickoff_section="$in_section"
      break
    elif [[ "$line" =~ ^\[ ]]; then
      in_section=""
    fi
  done < "$appletsrc"

  if [[ -n "$kickoff_section" ]]; then
    local cfg_section="${kickoff_section}[Configuration][General]"
    # Remove brackets for sed matching
    local cfg_escaped="${cfg_section//\[/\\[}"
    cfg_escaped="${cfg_escaped//\]/\\]}"
    if grep -q "^${cfg_escaped}$" "$appletsrc" 2>/dev/null; then
      if grep -q '^icon=' <(sed -n "/^${cfg_escaped}$/,/^\[/p" "$appletsrc"); then
        sed -i "/^${cfg_escaped}$/,/^\[/ s/^icon=.*/icon=umaos-launcher/" "$appletsrc"
      else
        sed -i "/^${cfg_escaped}$/a icon=umaos-launcher" "$appletsrc"
      fi
    else
      printf '\n%s\nicon=umaos-launcher\n' "$cfg_section" >> "$appletsrc"
    fi
  fi
}

if ((has_graphical_session == 1)); then
  apply_panel_properties
fi

if ((has_graphical_session == 1)); then
  # In --once mode, allow automatic retries for transient video setup failures.
  if ((once == 1)) && ((apply_video == 1)) && ((video_apply_failed == 1)) && ((video_fail_count < 3)); then
    rm -f "$state_file"
  else
    touch "$state_file"
  fi
fi
