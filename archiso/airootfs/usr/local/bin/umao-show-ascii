#!/usr/bin/env sh

# Show UmaOS system info on interactive terminal startup.
# Uses fastfetch when available; falls back to static ASCII art.

case "$-" in
  *i*) ;;
  *)
    return 0 2>/dev/null || exit 0
    ;;
esac

ascii_file="/usr/share/umaos/umaascii.txt"

if command -v fastfetch >/dev/null 2>&1; then
  fastfetch
elif [ -r "$ascii_file" ]; then
  cat "$ascii_file"
  printf '\n'
fi
