#!/usr/bin/env bash
set -euo pipefail

log() {
  printf '[umao-prepare-calamares] %s\n' "$*"
}

warn() {
  printf '[umao-prepare-calamares] WARN: %s\n' "$*" >&2
}

find_first_match() {
  local root="$1"
  local pattern="$2"
  local match

  [[ -d "$root" ]] || return 0
  match="$(find -L "$root" -maxdepth 12 -type f -name "$pattern" 2>/dev/null | sort | head -n1 || true)"
  printf '%s' "$match"
}

existing_unpack_conf_usable() {
  local unpack_conf="/etc/calamares/modules/unpackfs.conf"
  [[ -f "$unpack_conf" ]] || return 1
  if grep -Eq '/CHANGES|example|dummy' "$unpack_conf"; then
    return 1
  fi
  if grep -Eq 'airootfs\.(sfs|erofs)' "$unpack_conf"; then
    return 0
  fi
  return 1
}

prepare_unpackfs_config() {
  local unpack_conf="/etc/calamares/modules/unpackfs.conf"
  local airootfs_source=""
  local sourcefs="squashfs"
  local vmlinuz_source=""
  local initramfs_source=""
  local install_root=""
  local search_root
  local -a search_roots=(
    /run/archiso/bootmnt
    /run/archiso
    /run/media
    /media
    /mnt
  )

  for search_root in "${search_roots[@]}"; do
    airootfs_source="$(find_first_match "$search_root" "airootfs.sfs")"
    [[ -n "$airootfs_source" ]] && break
    airootfs_source="$(find_first_match "$search_root" "airootfs.erofs")"
    [[ -n "$airootfs_source" ]] && break
  done

  if [[ -z "$airootfs_source" ]]; then
    if existing_unpack_conf_usable; then
      warn "Unable to detect live-media airootfs image. Keeping existing unpackfs.conf."
      return 0
    fi
    log "Unable to locate airootfs image on live media."
    return 1
  fi

  if [[ "$airootfs_source" == *.erofs ]]; then
    sourcefs="erofs"
  fi

  install_root="$(dirname "$(dirname "$airootfs_source")")"
  if [[ -f "$install_root/boot/x86_64/vmlinuz-linux" ]]; then
    vmlinuz_source="$install_root/boot/x86_64/vmlinuz-linux"
  fi
  if [[ -f "$install_root/boot/x86_64/initramfs-linux.img" ]]; then
    initramfs_source="$install_root/boot/x86_64/initramfs-linux.img"
  fi

  if [[ -z "$vmlinuz_source" || -z "$initramfs_source" ]]; then
    for search_root in "${search_roots[@]}"; do
      if [[ -z "$vmlinuz_source" ]]; then
        vmlinuz_source="$(find -L "$search_root" -maxdepth 12 -type f -path '*/boot/x86_64/vmlinuz-linux' 2>/dev/null | sort | head -n1 || true)"
      fi
      if [[ -z "$initramfs_source" ]]; then
        initramfs_source="$(find -L "$search_root" -maxdepth 12 -type f -path '*/boot/x86_64/initramfs-linux.img' 2>/dev/null | sort | head -n1 || true)"
      fi
      [[ -n "$vmlinuz_source" && -n "$initramfs_source" ]] && break
    done
  fi

  mkdir -p /etc/calamares/modules
  {
    echo "---"
    echo "# Generated by /usr/local/bin/umao-prepare-calamares"
    echo "unpack:"
    echo "  - source: \"$airootfs_source\""
    echo "    sourcefs: \"$sourcefs\""
    echo "    destination: \"\""

    if [[ -n "$vmlinuz_source" ]]; then
      echo "  - source: \"$vmlinuz_source\""
      echo "    sourcefs: \"file\""
      echo "    destination: \"/boot/vmlinuz-linux\""
    fi

    if [[ -n "$initramfs_source" ]]; then
      echo "  - source: \"$initramfs_source\""
      echo "    sourcefs: \"file\""
      echo "    destination: \"/boot/initramfs-linux.img\""
    fi
  } > "$unpack_conf"

  log "Prepared unpackfs.conf using source: $airootfs_source ($sourcefs)"
  [[ -n "$vmlinuz_source" ]] && log "Kernel source: $vmlinuz_source"
  [[ -n "$initramfs_source" ]] && log "Initramfs source: $initramfs_source"
  [[ -z "$vmlinuz_source" ]] && warn "Kernel image not found on live media; relying on package-provided kernel."
  [[ -z "$initramfs_source" ]] && warn "Initramfs image not found on live media; relying on target generation."
}

prepare_unpackfs_config
echo "Umazing!"
