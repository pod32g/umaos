#!/usr/bin/env bash
set -euo pipefail

REPO_URL="${UMAOS_UPDATE_REPO:-https://github.com/pod32g/umaos}"
REF="${UMAOS_UPDATE_REF:-main}"

dry_run=0

usage() {
  cat <<'EOF'
Usage: uma-update [--ref <branch|tag|sha>] [--repo <url>] [--dry-run]

Downloads the latest UmaOS repository snapshot from GitHub and syncs
runtime scripts, themes, and configuration into the local system.

Default repo: https://github.com/pod32g/umaos
Default ref:  main

Options:
  --ref <ref>     Git reference to fetch (branch, tag, or commit)
  --repo <url>    Override repository URL
  --dry-run       Show what would be updated without writing
  --help          Show this help
EOF
}

log() {
  printf '[uma-update] %s\n' "$*"
}

die() {
  printf '[uma-update] ERROR: %s\n' "$*" >&2
  exit 1
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "Missing required command: $1"
}

while (($# > 0)); do
  case "$1" in
    --ref)
      shift
      [[ $# -gt 0 ]] || die "--ref requires a value"
      REF="$1"
      ;;
    --repo)
      shift
      [[ $# -gt 0 ]] || die "--repo requires a value"
      REPO_URL="$1"
      ;;
    --dry-run)
      dry_run=1
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      die "Unknown argument: $1"
      ;;
  esac
  shift
done

if [[ "${EUID:-$(id -u)}" -ne 0 ]]; then
  die "Run as root (use sudo) so system scripts can be updated."
fi

require_cmd curl
require_cmd tar
require_cmd install
require_cmd find

tmp_dir="$(mktemp -d)"
cleanup() {
  rm -rf "$tmp_dir"
}
trap cleanup EXIT

repo_url="${REPO_URL%/}"
archive_path="$tmp_dir/repo.tar.gz"

download_archive() {
  local url
  local -a candidates=(
    "${repo_url}/archive/refs/heads/${REF}.tar.gz"
    "${repo_url}/archive/refs/tags/${REF}.tar.gz"
    "${repo_url}/archive/${REF}.tar.gz"
  )
  for url in "${candidates[@]}"; do
    if curl -fsSL "$url" -o "$archive_path"; then
      log "Downloaded: $url"
      return 0
    fi
  done
  return 1
}

download_archive || die "Failed to download repo archive for ref '$REF' from '$repo_url'"

if ! tar -tzf "$archive_path" >/dev/null 2>&1; then
  die "Downloaded archive is corrupt or truncated. Check your network connection and try again."
fi

tar -xzf "$archive_path" -C "$tmp_dir"
repo_extract_dir="$(find "$tmp_dir" -mindepth 1 -maxdepth 1 -type d | head -n1 || true)"
[[ -n "$repo_extract_dir" && -d "$repo_extract_dir" ]] || die "Could not locate extracted repository directory"

updated=0
skipped=0

sync_dir_files() {
  local src_dir="$1"
  local dst_dir="$2"
  local file
  local dst_file
  local mode

  if [[ ! -d "$src_dir" ]]; then
    log "Skipping missing source directory: $src_dir"
    return 0
  fi

  mkdir -p "$dst_dir"

  while IFS= read -r -d '' file; do
    dst_file="$dst_dir/$(basename "$file")"
    mode="0644"
    if [[ -x "$file" ]]; then
      mode="0755"
    fi

    if cmp -s "$file" "$dst_file" 2>/dev/null; then
      skipped=$((skipped + 1))
      continue
    fi

    if ((dry_run == 1)); then
      log "Would update: $dst_file"
    else
      install -D -m "$mode" "$file" "$dst_file"
      log "Updated: $dst_file"
    fi
    updated=$((updated + 1))
  done < <(find "$src_dir" -maxdepth 1 -type f -print0 | sort -z)
}

# Recursive version: syncs all files preserving subdirectory structure.
sync_dir_recursive() {
  local src_dir="$1"
  local dst_dir="$2"
  local file
  local rel_path
  local dst_file
  local mode

  if [[ ! -d "$src_dir" ]]; then
    log "Skipping missing source directory: $src_dir"
    return 0
  fi

  while IFS= read -r -d '' file; do
    rel_path="${file#"$src_dir"/}"
    dst_file="$dst_dir/$rel_path"
    mode="0644"
    if [[ -x "$file" ]]; then
      mode="0755"
    fi

    if cmp -s "$file" "$dst_file" 2>/dev/null; then
      skipped=$((skipped + 1))
      continue
    fi

    if ((dry_run == 1)); then
      log "Would update: $dst_file"
    else
      install -D -m "$mode" "$file" "$dst_file"
      log "Updated: $dst_file"
    fi
    updated=$((updated + 1))
  done < <(find "$src_dir" -type f -print0 | sort -z)
}

airootfs="$repo_extract_dir/archiso/airootfs"
plymouth_changed=0
theme_changed_before=$updated

# ── 1. Runtime scripts ──
sync_dir_files "$airootfs/usr/local/bin" "/usr/local/bin"
sync_dir_files "$airootfs/etc/profile.d" "/etc/profile.d"
sync_dir_files "$airootfs/usr/share/applications" "/usr/share/applications"

# ── 2. Desktop launchers & autostart ──
sync_dir_files "$airootfs/etc/skel/Desktop" "/etc/skel/Desktop"
sync_dir_files "$airootfs/etc/skel/.config/autostart" "/etc/skel/.config/autostart"

# ── 3. SDDM login theme ──
sync_dir_files "$airootfs/usr/share/sddm/themes/umaos-race" "/usr/share/sddm/themes/umaos-race"

# ── 4. Plymouth boot splash ──
theme_changed_before=$updated
sync_dir_files "$airootfs/usr/share/plymouth/themes/umaos" "/usr/share/plymouth/themes/umaos"
if ((updated > theme_changed_before)); then
  plymouth_changed=1
fi

# ── 5. Konsole terminal themes & profiles ──
sync_dir_files "$airootfs/usr/share/konsole" "/usr/share/konsole"

# ── 6. KDE color schemes ──
sync_dir_files "$airootfs/usr/share/color-schemes" "/usr/share/color-schemes"

# ── 7. UmaOS shared assets (recursive — has subdirs) ──
sync_dir_recursive "$airootfs/usr/share/umaos" "/usr/share/umaos"

# ── 8. KDE Look and Feel lock screen (recursive) ──
sync_dir_recursive "$airootfs/usr/share/plasma/look-and-feel/com.umaos.desktop" \
  "/usr/share/plasma/look-and-feel/com.umaos.desktop"

# ── 9. Breeze lock screen avatar patch (circular clip fallback) ──
# The default UserDelegate.qml uses a GPU ShaderEffect for the circular avatar.
# On software rendering or certain GPU drivers the shader fails silently,
# leaving a rectangular avatar. Our patched version adds clip+radius to the
# image container so it's always circular.
sync_dir_files "$airootfs/usr/lib/qt6/qml/org/kde/breeze/components" \
  "/usr/lib/qt6/qml/org/kde/breeze/components"

# ── 9b. Force Qt6 to load QML from filesystem instead of compiled resources ──
# plasma-workspace compiles QML files into libcomponents.so and the generated
# qmldir contains a "prefer :/qt/qml/..." line.  This causes Qt6 to use the
# compiled-in versions, completely ignoring our patched UserDelegate.qml on
# disk.  Removing the "prefer" line makes Qt6 load from the filesystem.
breeze_qmldir="/usr/lib/qt6/qml/org/kde/breeze/components/qmldir"
if [[ -f "$breeze_qmldir" ]] && grep -q '^prefer ' "$breeze_qmldir"; then
  if ((dry_run == 1)); then
    log "Would patch: $breeze_qmldir (remove 'prefer' directive)"
  else
    sed -i '/^prefer /d' "$breeze_qmldir"
    log "Patched: $breeze_qmldir (removed 'prefer' directive so filesystem QML is used)"
  fi
  updated=$((updated + 1))
fi

# ── 10. Skel KDE/GTK config files ──
# These are the source files that get copied to each user's home.
for cfg in kdeglobals kcminputrc ksplashrc kscreenlockerrc kwinrc konsolerc mimeapps.list; do
  if [[ -f "$airootfs/etc/skel/.config/$cfg" ]]; then
    sync_dir_files "$airootfs/etc/skel/.config" "/etc/skel/.config"
    break  # sync_dir_files handles the whole flat dir at once
  fi
done
sync_dir_files "$airootfs/etc/skel/.config/fastfetch" "/etc/skel/.config/fastfetch"
sync_dir_files "$airootfs/etc/skel/.config/gtk-3.0" "/etc/skel/.config/gtk-3.0"
sync_dir_files "$airootfs/etc/skel/.config/gtk-4.0" "/etc/skel/.config/gtk-4.0"
sync_dir_files "$airootfs/etc/skel/.config/conky" "/etc/skel/.config/conky"
sync_dir_recursive "$airootfs/etc/skel/.config/nvim" "/etc/skel/.config/nvim"

# ── 11. Pacman hooks & config ──
sync_dir_files "$airootfs/etc/pacman.d/hooks" "/etc/pacman.d/hooks"

# ── 12. Sudo lecture ──
sync_dir_files "$airootfs/etc/sudoers.d" "/etc/sudoers.d"

# ── 13. Helium browser policies ──
sync_dir_recursive "$airootfs/etc/helium" "/etc/helium"

# ── Post-sync: propagate theme changes to existing users ──
propagate_to_users() {
  log "Propagating updated configs to existing users..."
  local user_name user_home uid gid
  while IFS=: read -r user_name _ uid gid _ user_home _; do
    [[ "$uid" =~ ^[0-9]+$ ]] || continue
    (( uid >= 1000 && uid < 60000 )) || continue
    [[ "$user_home" != "/" && -n "$user_home" && -d "$user_home" ]] || continue

    # Sync skel config files to user home.
    # NOTE: kcminputrc is excluded — it contains cursor theme which is a
    # user preference that should not be overwritten on update.
    for src in kdeglobals ksplashrc kscreenlockerrc kwinrc konsolerc mimeapps.list; do
      if [[ -f "/etc/skel/.config/$src" ]]; then
        install -D -m 600 -o "$uid" -g "$gid" "/etc/skel/.config/$src" "$user_home/.config/$src"
      fi
    done

    # Sync fastfetch config
    if [[ -f "/etc/skel/.config/fastfetch/config.jsonc" ]]; then
      install -D -m 600 -o "$uid" -g "$gid" "/etc/skel/.config/fastfetch/config.jsonc" \
        "$user_home/.config/fastfetch/config.jsonc"
    fi

    # NOTE: GTK settings (gtk-3.0, gtk-4.0) are excluded from propagation
    # because they contain cursor theme preferences that should not be
    # overwritten on update.

    # Sync desktop launchers
    for launcher in "Install Uma Musume.sh" "UmaOS Update.desktop" "Driver Setup.desktop" "Audio Doctor.desktop" "Change Cursor.desktop"; do
      if [[ -f "/etc/skel/Desktop/$launcher" ]]; then
        install -D -m 755 -o "$uid" -g "$gid" "/etc/skel/Desktop/$launcher" \
          "$user_home/Desktop/$launcher"
      fi
    done

    # Sync conky config
    if [[ -f "/etc/skel/.config/conky/conky.conf" ]]; then
      install -D -m 600 -o "$uid" -g "$gid" "/etc/skel/.config/conky/conky.conf" \
        "$user_home/.config/conky/conky.conf"
    fi

    # Sync nvim (NvChad) config — only Lua source files, not plugin data
    if [[ -d "/etc/skel/.config/nvim" ]]; then
      local nvim_src="/etc/skel/.config/nvim"
      local nvim_dst="$user_home/.config/nvim"
      for nvim_file in init.lua .stylua.toml; do
        if [[ -f "$nvim_src/$nvim_file" ]]; then
          install -D -m 600 -o "$uid" -g "$gid" "$nvim_src/$nvim_file" "$nvim_dst/$nvim_file"
        fi
      done
      if [[ -d "$nvim_src/lua" ]]; then
        while IFS= read -r -d '' file; do
          local rel="${file#"$nvim_src"/}"
          install -D -m 600 -o "$uid" -g "$gid" "$file" "$nvim_dst/$rel"
        done < <(find "$nvim_src/lua" -type f -print0 | sort -z)
      fi
    fi

    # Sync autostart entries
    for entry in umaos-welcome.desktop umaos-login-sound.desktop umaos-conky.desktop; do
      if [[ -f "/etc/skel/.config/autostart/$entry" ]]; then
        install -D -m 644 -o "$uid" -g "$gid" "/etc/skel/.config/autostart/$entry" \
          "$user_home/.config/autostart/$entry"
      fi
    done

    # Sync Dolphin sidebar bookmarks (only if user hasn't customized theirs)
    if [[ -f "/etc/skel/.local/share/user-places.xbel" ]] && [[ ! -f "$user_home/.local/share/user-places.xbel" ]]; then
      install -D -m 600 -o "$uid" -g "$gid" "/etc/skel/.local/share/user-places.xbel" \
        "$user_home/.local/share/user-places.xbel"
    fi

    log "Synced configs for user '$user_name'."
  done < /etc/passwd
}

# ── Post-sync: rebuild initramfs if Plymouth theme changed ──
rebuild_plymouth() {
  if command -v plymouth-set-default-theme >/dev/null 2>&1; then
    if [[ -f /usr/share/plymouth/themes/umaos/umaos.plymouth ]]; then
      plymouth-set-default-theme umaos
      log "Plymouth default theme set to umaos."
    fi
  fi
  if command -v mkinitcpio >/dev/null 2>&1; then
    log "Rebuilding initramfs to apply Plymouth changes..."
    mkinitcpio -P 2>&1 | tail -5 || log "WARNING: mkinitcpio rebuild returned errors."
    log "Initramfs rebuilt."
  fi
}

if ((dry_run == 1)); then
  log "Dry-run complete. Files to update: $updated, unchanged: $skipped."
else
  log "Sync complete. Files updated: $updated, unchanged: $skipped."

  # Always sync face icons to SDDM faces directory.
  # Home dirs may be mode 700, so SDDM can't read ~/.face.icon.
  # Copy AccountsService icons to /usr/share/sddm/faces/ where SDDM can find them.
  sync_sddm_face_icons() {
    local user_name uid
    while IFS=: read -r user_name _ uid _ _ _ _; do
      [[ "$uid" =~ ^[0-9]+$ ]] || continue
      (( uid >= 1000 && uid < 60000 )) || continue
      if [[ -f "/var/lib/AccountsService/icons/$user_name" ]]; then
        local dest="/usr/share/sddm/faces/${user_name}.face.icon"
        if ! cmp -s "/var/lib/AccountsService/icons/$user_name" "$dest" 2>/dev/null; then
          install -D -m 644 "/var/lib/AccountsService/icons/$user_name" "$dest"
          log "Synced face icon for '$user_name' to SDDM faces dir."
        fi
      fi
    done < /etc/passwd
  }
  sync_sddm_face_icons

  if ((updated > 0)); then
    propagate_to_users

    if ((plymouth_changed == 1)); then
      rebuild_plymouth
    fi
  fi

  echo "Umazing!"
fi
