#!/usr/bin/env python3
"""UmaOS Dev Environment Setup — Qt6/QML GUI with kdialog & text fallbacks."""

import os
import sys
import subprocess
import shutil
from dataclasses import dataclass, field

# ── Stack definitions ──────────────────────────────────────────────────────────

CATEGORIES = ["languages", "editors", "ai", "devops", "data"]

@dataclass
class Stack:
    tag: str
    display_name: str
    check_cmd: str
    category: str
    packages: list[str] = field(default_factory=list)

    @property
    def installed(self) -> bool:
        return shutil.which(self.check_cmd) is not None

    def to_dict(self) -> dict:
        return {
            "tag": self.tag,
            "displayName": self.display_name,
            "category": self.category,
            "packages": self.packages,
            "installed": self.installed,
        }

STACKS = [
    # Languages
    Stack("web", "Web Development", "node", "languages", ["nodejs", "npm", "typescript", "prettier"]),
    Stack("python", "Python", "python3", "languages", ["python", "python-pip", "python-virtualenv"]),
    Stack("rust", "Rust", "rustup", "languages", ["rustup"]),
    Stack("go", "Go", "go", "languages", ["go"]),
    Stack("java", "Java", "javac", "languages", ["jdk-openjdk", "gradle"]),
    Stack("cpp", "C/C++ Toolchain", "clang", "languages", ["clang", "cmake", "gdb", "valgrind"]),
    # Editors
    Stack("vscode", "VS Code", "code", "editors", ["code"]),
    Stack("neovim", "Neovim", "nvim", "editors", ["neovim"]),
    Stack("helix", "Helix", "hx", "editors", ["helix"]),
    Stack("emacs", "Emacs", "emacs", "editors", ["emacs"]),
    # AI
    Stack("ollama", "Ollama", "ollama", "ai", ["ollama"]),
    Stack("claude-code", "Claude Code", "claude", "ai", ["nodejs", "npm"]),
    Stack("aider", "Aider", "aider", "ai", ["python", "python-pipx"]),
    Stack("codex", "OpenAI Codex", "codex", "ai", ["nodejs", "npm"]),
    Stack("gemini-cli", "Gemini CLI", "gemini", "ai", ["nodejs", "npm"]),
    Stack("opencode", "OpenCode", "opencode", "ai", ["opencode-bin"]),
    Stack("cursor", "Cursor", "cursor", "ai", ["cursor-bin"]),
    # DevOps
    Stack("docker", "Docker & Compose", "docker", "devops", ["docker", "docker-compose"]),
    Stack("k8s", "Kubernetes", "kubectl", "devops", ["kubectl", "helm"]),
    Stack("terraform", "Terraform", "terraform", "devops", ["terraform"]),
    Stack("ansible", "Ansible", "ansible", "devops", ["ansible"]),
    # Data
    Stack("postgresql", "PostgreSQL", "postgres", "data", ["postgresql"]),
    Stack("redis", "Redis", "redis-server", "data", ["redis"]),
    Stack("sqlite", "SQLite", "sqlite3", "data", ["sqlite"]),
    Stack("mongodb", "MongoDB", "mongosh", "data", ["mongosh"]),
]

STACKS_BY_TAG = {s.tag: s for s in STACKS}

# ── Post-install hooks ─────────────────────────────────────────────────────────

def run_post_hooks(tags: list[str]) -> None:
    for tag in tags:
        stack = STACKS_BY_TAG.get(tag)
        if not stack:
            continue
        if stack.tag == "rust" and shutil.which("rustup"):
            subprocess.run(["rustup", "default", "stable"],
                           capture_output=True)
        elif stack.tag == "claude-code" and shutil.which("npm"):
            subprocess.run(["npm", "install", "-g", "@anthropic-ai/claude-code"],
                           capture_output=True)
        elif stack.tag == "codex" and shutil.which("npm"):
            subprocess.run(["npm", "install", "-g", "@openai/codex"],
                           capture_output=True)
        elif stack.tag == "gemini-cli" and shutil.which("npm"):
            subprocess.run(["npm", "install", "-g", "@google/gemini-cli"],
                           capture_output=True)
        elif stack.tag == "aider" and shutil.which("pipx"):
            subprocess.run(["pipx", "install", "aider-chat"],
                           capture_output=True)
        elif stack.tag == "ollama" and shutil.which("ollama"):
            subprocess.run(["sudo", "systemctl", "enable", "--now", "ollama.service"],
                           capture_output=True)
        elif stack.tag == "docker" and shutil.which("docker"):
            subprocess.run(["sudo", "systemctl", "enable", "--now", "docker.service"],
                           capture_output=True)
            user = os.environ.get("SUDO_USER") or os.environ.get("USER", "")
            if user:
                groups_out = subprocess.run(["groups", user], capture_output=True, text=True)
                if "docker" not in groups_out.stdout:
                    subprocess.run(["sudo", "usermod", "-aG", "docker", user],
                                   capture_output=True)
        elif stack.tag == "postgresql" and shutil.which("postgres"):
            pg_data = "/var/lib/postgres/data"
            if not os.path.isdir(os.path.join(pg_data, "base")):
                subprocess.run(["sudo", "-u", "postgres", "initdb", "-D", pg_data],
                               capture_output=True)
            subprocess.run(["sudo", "systemctl", "enable", "--now", "postgresql.service"],
                           capture_output=True)
        elif stack.tag == "redis" and shutil.which("redis-server"):
            subprocess.run(["sudo", "systemctl", "enable", "--now", "redis.service"],
                           capture_output=True)


# ── Helpers ────────────────────────────────────────────────────────────────────

def has_display() -> bool:
    return bool(os.environ.get("DISPLAY") or os.environ.get("WAYLAND_DISPLAY"))

def dedupe_packages(tags: list[str]) -> list[str]:
    seen = {}
    for tag in tags:
        stack = STACKS_BY_TAG.get(tag)
        if stack:
            for pkg in stack.packages:
                if pkg not in seen:
                    seen[pkg] = True
    return list(seen.keys())

def classify_packages(pkgs: list[str]) -> tuple[list[str], list[str]]:
    """Split into (official, aur) packages."""
    official, aur = [], []
    for pkg in pkgs:
        ret = subprocess.run(["pacman", "-Si", pkg],
                             capture_output=True, timeout=10)
        if ret.returncode == 0:
            official.append(pkg)
        else:
            aur.append(pkg)
    return official, aur


# ═══════════════════════════════════════════════════════════════════════════════
# QML GUI mode (PyQt6)
# ═══════════════════════════════════════════════════════════════════════════════

def run_qml() -> None:
    from PyQt6.QtCore import (
        QObject, QThread, QUrl, pyqtSignal, pyqtSlot, pyqtProperty, QVariant
    )
    from PyQt6.QtGui import QGuiApplication, QIcon
    from PyQt6.QtQml import QQmlApplicationEngine

    class InstallWorker(QThread):
        progressChanged = pyqtSignal(int, int)
        currentPackageChanged = pyqtSignal(str)
        packageCompleted = pyqtSignal(str)
        installComplete = pyqtSignal(str, str)
        installError = pyqtSignal(str)

        def __init__(self, tags: list[str], parent=None):
            super().__init__(parent)
            self.tags = tags

        def run(self):
            try:
                all_pkgs = dedupe_packages(self.tags)
                if not all_pkgs:
                    self.installError.emit("No packages to install.")
                    return

                total = len(all_pkgs)
                official, aur = classify_packages(all_pkgs)
                completed = set()
                done = 0

                # Install official packages via single pkexec call
                if official:
                    self.currentPackageChanged.emit(official[0])
                    proc = subprocess.Popen(
                        ["pkexec", "pacman", "-S", "--needed", "--noconfirm"] + official,
                        stdout=subprocess.PIPE, stderr=subprocess.STDOUT,
                        text=True, bufsize=1,
                    )
                    for line in proc.stdout:
                        line = line.strip()
                        for prefix in ("installing ", "reinstalling "):
                            if line.lower().startswith(prefix):
                                pkg = line[len(prefix):].rstrip(".").strip()
                                if pkg in official and pkg not in completed:
                                    completed.add(pkg)
                                    done += 1
                                    self.packageCompleted.emit(pkg)
                                    self.progressChanged.emit(done, total)
                                    remaining = [p for p in official if p not in completed]
                                    if remaining:
                                        self.currentPackageChanged.emit(remaining[0])
                    proc.wait()
                    if proc.returncode != 0 and not completed:
                        # pkexec or pacman failed entirely
                        self.installError.emit(
                            "Installation failed (exit code "
                            + str(proc.returncode)
                            + "). Authentication may have been cancelled."
                        )
                        return
                    # Mark any un-tracked official packages as done
                    # (pacman installs all-or-nothing with --needed)
                    for pkg in official:
                        if pkg not in completed:
                            completed.add(pkg)
                            done += 1
                            self.packageCompleted.emit(pkg)
                            self.progressChanged.emit(done, total)

                # Install AUR packages
                aur_warning = ""
                if aur:
                    if shutil.which("yay"):
                        for pkg in aur:
                            self.currentPackageChanged.emit(pkg)
                            subprocess.run(
                                ["yay", "-S", "--needed", "--noconfirm", pkg],
                                capture_output=True,
                            )
                            done += 1
                            self.packageCompleted.emit(pkg)
                            self.progressChanged.emit(done, total)
                    else:
                        aur_warning = (
                            "yay is not installed. These AUR packages "
                            "need manual install: " + ", ".join(aur)
                        )
                        for pkg in aur:
                            done += 1
                            self.progressChanged.emit(done, total)

                run_post_hooks(self.tags)

                stack_names = []
                for tag in self.tags:
                    s = STACKS_BY_TAG.get(tag)
                    if s:
                        stack_names.append(s.display_name)
                summary = (
                    f"Installed {len(all_pkgs)} packages across "
                    f"{len(self.tags)} stacks: {', '.join(stack_names)}."
                )
                self.installComplete.emit(summary, aur_warning)

            except Exception as e:
                self.installError.emit(str(e))

    class DevSetupBackend(QObject):
        progressChanged = pyqtSignal(int, int, arguments=["current", "total"])
        currentPackageChanged = pyqtSignal(str, arguments=["pkg"])
        packageCompleted = pyqtSignal(str, arguments=["pkg"])
        installComplete = pyqtSignal(str, str, arguments=["summary", "warning"])
        installError = pyqtSignal(str, arguments=["error"])

        def __init__(self, parent=None):
            super().__init__(parent)
            self._stacks = [s.to_dict() for s in STACKS]
            self._categories = CATEGORIES
            self._worker = None

        @pyqtProperty("QVariantList", constant=True)
        def stacks(self):
            return self._stacks

        @pyqtProperty("QVariantList", constant=True)
        def categories(self):
            return self._categories

        @pyqtSlot("QVariantList")
        def install(self, tags):
            tag_list = list(tags)
            self._worker = InstallWorker(tag_list, self)
            self._worker.progressChanged.connect(self.progressChanged)
            self._worker.currentPackageChanged.connect(self.currentPackageChanged)
            self._worker.packageCompleted.connect(self.packageCompleted)
            self._worker.installComplete.connect(self.installComplete)
            self._worker.installError.connect(self.installError)
            self._worker.start()

    app = QGuiApplication(sys.argv)
    app.setApplicationName("UmaOS Dev Setup")

    icon_path = "/usr/share/umaos/dev-setup/icon.png"
    if os.path.exists(icon_path):
        app.setWindowIcon(QIcon(icon_path))

    engine = QQmlApplicationEngine()
    backend = DevSetupBackend()
    engine.rootContext().setContextProperty("backend", backend)

    qml_dir = "/usr/share/umaos/dev-setup"
    engine.addImportPath(qml_dir)
    engine.load(QUrl.fromLocalFile(os.path.join(qml_dir, "main.qml")))

    if not engine.rootObjects():
        print("Error: Failed to load QML interface.", file=sys.stderr)
        sys.exit(1)

    sys.exit(app.exec())


# ═══════════════════════════════════════════════════════════════════════════════
# kdialog fallback
# ═══════════════════════════════════════════════════════════════════════════════

def run_kdialog() -> None:
    TITLE = "UmaOS Dev Setup"
    ICON = "/usr/share/umaos/dev-setup/icon.png"

    args = []
    for s in STACKS:
        state = "on" if s.installed else "off"
        label = f"{s.display_name}  ({len(s.packages)} packages)"
        args += [s.tag, label, state]

    try:
        result = subprocess.run(
            ["kdialog", "--icon", ICON, "--title", TITLE,
             "--checklist", "Select development stacks to install:"] + args,
            capture_output=True, text=True,
        )
    except FileNotFoundError:
        return run_text()

    if result.returncode != 0 or not result.stdout.strip():
        return

    selection = result.stdout.strip().replace('"', '').split()
    tags = [t for t in selection if t in STACKS_BY_TAG]
    if not tags:
        return

    all_pkgs = dedupe_packages(tags)
    stack_names = [STACKS_BY_TAG[t].display_name for t in tags]

    summary = "Install the following stacks?\n\n"
    summary += "\n".join(f"  - {n}" for n in stack_names)
    summary += f"\n\n{len(all_pkgs)} packages total: {' '.join(all_pkgs)}"

    ret = subprocess.run(
        ["kdialog", "--icon", ICON, "--title", TITLE, "--yesno", summary],
        capture_output=True,
    )
    if ret.returncode != 0:
        return

    official, aur = classify_packages(all_pkgs)
    total = len(all_pkgs)
    dbus = subprocess.run(
        ["kdialog", "--icon", ICON, "--title", TITLE,
         "--progressbar", "Preparing installation...", str(total)],
        capture_output=True, text=True,
    ).stdout.strip()

    done = 0

    def update_progress(label, value):
        subprocess.run(["qdbus6", dbus, "setLabelText", label],
                       capture_output=True)
        subprocess.run(["qdbus6", dbus, "Set", "", "value", str(value)],
                       capture_output=True)

    if official:
        for pkg in official:
            update_progress(f"Installing {pkg}...", done)
            subprocess.run(["sudo", "pacman", "-S", "--needed", "--noconfirm", pkg],
                           capture_output=True)
            done += 1

    if aur:
        if shutil.which("yay"):
            for pkg in aur:
                update_progress(f"Installing {pkg} (AUR)...", done)
                subprocess.run(["yay", "-S", "--needed", "--noconfirm", pkg],
                               capture_output=True)
                done += 1
        else:
            done += len(aur)

    update_progress("Done!", total)
    subprocess.run(["qdbus6", dbus, "close"], capture_output=True)

    run_post_hooks(tags)

    msg = "Umazing! Dev environment is ready."
    if aur and not shutil.which("yay"):
        msg += f"\n\nyay is not installed. These AUR packages need manual install:\n{' '.join(aur)}"

    subprocess.run(["kdialog", "--icon", ICON, "--title", TITLE,
                     "--passivepopup", msg, "5"], capture_output=True)
    subprocess.run(["kdialog", "--icon", ICON, "--title", TITLE,
                     "--msgbox", msg], capture_output=True)


# ═══════════════════════════════════════════════════════════════════════════════
# Text fallback
# ═══════════════════════════════════════════════════════════════════════════════

def run_text() -> None:
    print()
    print("  UmaOS Dev Environment Setup")
    print("  (text mode — no graphical session detected)")
    print("  " + "━" * 43)
    print()

    for i, s in enumerate(STACKS):
        marker = " *" if s.installed else "  "
        pkgs_str = " ".join(s.packages)
        print(f"  {marker} {i+1:2d}) {s.display_name:<22s}  [{pkgs_str}]")

    print()
    print("  Enter stack numbers separated by spaces (e.g. 1 3 5)")
    print("  Or 'all' to install everything, 'q' to quit.")
    print()

    try:
        inp = input("  Select stacks: ").strip()
    except (EOFError, KeyboardInterrupt):
        print()
        return

    if inp in ("q", ""):
        print("  Nothing to install.")
        return

    tags = []
    if inp == "all":
        tags = [s.tag for s in STACKS]
    else:
        for num in inp.split():
            if not num.isdigit():
                print(f"  Skipping invalid selection: {num}")
                continue
            idx = int(num) - 1
            if 0 <= idx < len(STACKS):
                tags.append(STACKS[idx].tag)
            else:
                print(f"  Skipping invalid selection: {num}")

    if not tags:
        print("  No valid stacks selected.")
        return

    all_pkgs = dedupe_packages(tags)
    stack_names = [STACKS_BY_TAG[t].display_name for t in tags]

    print()
    print(f"  Installing: {', '.join(stack_names)}")
    print(f"  Packages:   {' '.join(all_pkgs)}")
    print()

    official, aur = classify_packages(all_pkgs)

    if official:
        print("  >> Installing from official repos...")
        subprocess.run(["sudo", "pacman", "-S", "--needed", "--noconfirm"] + official)

    if aur:
        if shutil.which("yay"):
            print("  >> Installing from AUR...")
            subprocess.run(["yay", "-S", "--needed", "--noconfirm"] + aur)
        else:
            print("  WARNING: yay not found. These AUR packages need manual install:")
            for pkg in aur:
                print(f"    {pkg}")

    run_post_hooks(tags)

    print()
    print("  Umazing! Dev environment is ready.")
    print()


# ═══════════════════════════════════════════════════════════════════════════════
# Entry point
# ═══════════════════════════════════════════════════════════════════════════════

def main() -> None:
    if "--text" in sys.argv:
        return run_text()

    if not has_display():
        return run_text()

    # Try PyQt6 QML GUI
    try:
        import PyQt6.QtCore  # noqa: F401
        return run_qml()
    except ImportError:
        pass

    # Try kdialog
    if shutil.which("kdialog"):
        return run_kdialog()

    return run_text()


if __name__ == "__main__":
    main()
