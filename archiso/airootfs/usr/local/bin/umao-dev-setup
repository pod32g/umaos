#!/usr/bin/env bash
set -euo pipefail

# UmaOS Dev Environment Setup
# Interactive TUI for installing development tool stacks.

# ── Stack definitions ──
# Each stack: NAME|CHECK_CMD|PACKAGES (space-separated)

STACKS=(
  "Web Dev|node|nodejs npm typescript prettier"
  "Python|python3|python python-pip python-virtualenv"
  "Rust|rustup|rustup"
  "Go|go|go"
  "Java|javac|jdk-openjdk gradle"
  "C/C++ Toolchain|clang|clang cmake gdb valgrind"
  "DevOps|docker|docker docker-compose kubectl helm"
  "Database|sqlite3|sqlite postgresql redis"
)

get_name()  { echo "${1%%|*}"; }
get_check() { local rest="${1#*|}"; echo "${rest%%|*}"; }
get_pkgs()  { echo "${1##*|}"; }

is_installed() {
  command -v "$1" >/dev/null 2>&1
}

echo ""
echo "  🐴 UmaOS Dev Environment Setup"
echo "  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

for i in "${!STACKS[@]}"; do
  name="$(get_name "${STACKS[$i]}")"
  check="$(get_check "${STACKS[$i]}")"
  pkgs="$(get_pkgs "${STACKS[$i]}")"

  if is_installed "$check"; then
    marker=" ✓"
  else
    marker="  "
  fi

  printf "  %s %2d) %-20s  [%s]\n" "$marker" "$((i + 1))" "$name" "$pkgs"
done

echo ""
echo "  Enter stack numbers separated by spaces (e.g. 1 3 5)"
echo "  Or 'all' to install everything, 'q' to quit."
echo ""
read -rp "  Select stacks: " input

if [[ "$input" == "q" || -z "$input" ]]; then
  echo "  Nothing to install."
  exit 0
fi

# Parse selections
declare -a selected_pkgs=()
declare -a selected_names=()

if [[ "$input" == "all" ]]; then
  for i in "${!STACKS[@]}"; do
    selected_names+=("$(get_name "${STACKS[$i]}")")
    for pkg in $(get_pkgs "${STACKS[$i]}"); do
      selected_pkgs+=("$pkg")
    done
  done
else
  for num in $input; do
    if ! [[ "$num" =~ ^[0-9]+$ ]] || (( num < 1 || num > ${#STACKS[@]} )); then
      echo "  Skipping invalid selection: $num"
      continue
    fi
    idx=$((num - 1))
    selected_names+=("$(get_name "${STACKS[$idx]}")")
    for pkg in $(get_pkgs "${STACKS[$idx]}"); do
      selected_pkgs+=("$pkg")
    done
  done
fi

if [[ ${#selected_pkgs[@]} -eq 0 ]]; then
  echo "  No valid stacks selected."
  exit 1
fi

# Deduplicate packages
mapfile -t unique_pkgs < <(printf '%s\n' "${selected_pkgs[@]}" | sort -u)

echo ""
echo "  Installing: ${selected_names[*]}"
echo "  Packages:   ${unique_pkgs[*]}"
echo ""

# Separate official repo packages from AUR-only packages.
# Try pacman first; anything it can't find goes through yay.
declare -a pacman_pkgs=()
declare -a aur_pkgs=()

for pkg in "${unique_pkgs[@]}"; do
  if pacman -Si "$pkg" >/dev/null 2>&1; then
    pacman_pkgs+=("$pkg")
  else
    aur_pkgs+=("$pkg")
  fi
done

if [[ ${#pacman_pkgs[@]} -gt 0 ]]; then
  echo "  >> Installing from official repos..."
  sudo pacman -S --needed --noconfirm "${pacman_pkgs[@]}"
fi

if [[ ${#aur_pkgs[@]} -gt 0 ]]; then
  if command -v yay >/dev/null 2>&1; then
    echo "  >> Installing from AUR..."
    yay -S --needed --noconfirm "${aur_pkgs[@]}"
  else
    echo "  WARNING: yay not found. These AUR packages need manual install:"
    printf "    %s\n" "${aur_pkgs[@]}"
  fi
fi

# Post-install hooks
for name in "${selected_names[@]}"; do
  case "$name" in
    Rust)
      if command -v rustup >/dev/null 2>&1; then
        echo "  >> Setting up Rust stable toolchain..."
        rustup default stable 2>/dev/null || true
      fi
      ;;
    DevOps)
      if command -v docker >/dev/null 2>&1; then
        echo "  >> Enabling Docker service..."
        sudo systemctl enable --now docker.service 2>/dev/null || true
        if ! groups | grep -q docker; then
          sudo usermod -aG docker "$USER" 2>/dev/null || true
          echo "  NOTE: Log out and back in for Docker group access."
        fi
      fi
      ;;
    Database)
      if command -v postgres >/dev/null 2>&1; then
        echo "  >> Initializing PostgreSQL..."
        if [[ ! -d /var/lib/postgres/data/base ]]; then
          sudo -u postgres initdb -D /var/lib/postgres/data 2>/dev/null || true
        fi
        sudo systemctl enable --now postgresql.service 2>/dev/null || true
      fi
      if command -v redis-server >/dev/null 2>&1; then
        sudo systemctl enable --now redis.service 2>/dev/null || true
      fi
      ;;
  esac
done

echo ""
echo "  Umazing! Dev environment is ready."
echo ""
