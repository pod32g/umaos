#!/usr/bin/env bash
set -euo pipefail

# UmaOS Cursor Theme Switcher
# Lets users choose from the 24 Uma Musume character cursor packs.

ICON_DIR="/usr/share/icons"
KWRITE=""

for cmd in kwriteconfig6 kwriteconfig5; do
  if command -v "$cmd" >/dev/null 2>&1; then
    KWRITE="$cmd"
    break
  fi
done

# Discover installed pixloen cursor themes
mapfile -t themes < <(
  for d in "$ICON_DIR"/pixloen-*; do
    [[ -d "$d/cursors" ]] && basename "$d"
  done | sort
)

if [[ ${#themes[@]} -eq 0 ]]; then
  echo "No pixloen cursor themes found in $ICON_DIR."
  exit 1
fi

# Extract friendly character names
declare -a names=()
for t in "${themes[@]}"; do
  # pixloen-haru-urara-v1.7 → Haru Urara
  name="${t#pixloen-}"            # remove prefix
  name="${name%-v[0-9]*}"         # remove version suffix
  name="${name//-cursor-pack/}"   # remove -cursor-pack
  name="${name//-/ }"             # dashes to spaces
  # Title case
  name="$(echo "$name" | sed 's/\b\(.\)/\u\1/g')"
  names+=("$name")
done

# Get current cursor theme
current=""
if [[ -f "$HOME/.config/kcminputrc" ]]; then
  current="$(grep -oP 'cursorTheme=\K.*' "$HOME/.config/kcminputrc" 2>/dev/null || true)"
fi

echo ""
echo "  🐴 UmaOS Cursor Theme Switcher"
echo "  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

for i in "${!themes[@]}"; do
  marker="  "
  if [[ "${themes[$i]}" == "$current" ]]; then
    marker="▸ "
  fi
  printf "  %s%2d) %s\n" "$marker" "$((i + 1))" "${names[$i]}"
done

echo ""
read -rp "  Choose cursor (1-${#themes[@]}): " choice

if ! [[ "$choice" =~ ^[0-9]+$ ]] || (( choice < 1 || choice > ${#themes[@]} )); then
  echo "  Invalid choice."
  exit 1
fi

selected="${themes[$((choice - 1))]}"
selected_name="${names[$((choice - 1))]}"

echo ""
echo "  Applying: $selected_name ($selected)"

# Update KDE config
if [[ -n "$KWRITE" ]]; then
  "$KWRITE" --file kcminputrc --group Mouse --key cursorTheme "$selected"
  "$KWRITE" --file kcminputrc --group Mouse --key cursorThemeName "$selected"
fi

# Update GTK configs
for gtk_ver in gtk-3.0 gtk-4.0; do
  cfg="$HOME/.config/$gtk_ver/settings.ini"
  if [[ -f "$cfg" ]]; then
    sed -i "s/^gtk-cursor-theme-name=.*/gtk-cursor-theme-name=$selected/" "$cfg"
  fi
done

# Update X11 default cursor
mkdir -p "$HOME/.icons/default"
cat > "$HOME/.icons/default/index.theme" <<EOF
[Icon Theme]
Inherits=$selected
EOF

# Try to apply immediately via qdbus
for qdbus_cmd in qdbus6 qdbus-qt6 qdbus; do
  if command -v "$qdbus_cmd" >/dev/null 2>&1; then
    "$qdbus_cmd" org.kde.KWin /KWin reconfigure 2>/dev/null || true
    break
  fi
done

echo "  Done! $selected_name cursor is now active."
echo "  (Log out and back in if it doesn't update immediately.)"
echo ""
