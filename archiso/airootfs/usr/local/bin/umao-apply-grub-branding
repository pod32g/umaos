#!/usr/bin/env bash
set -euo pipefail

log() {
  printf '[umao-apply-grub-branding] %s\n' "$*"
}

find_background_source() {
  local candidate
  for candidate in \
    /usr/share/wallpapers/UmaBoot/contents/images/1920x1080.png \
    /usr/share/wallpapers/UmaOS/contents/images/1920x1080.jpg \
    /usr/share/wallpapers/UmaOS/contents/images/3840x2160.jpg; do
    if [[ -f "$candidate" ]]; then
      printf '%s' "$candidate"
      return 0
    fi
  done
  return 1
}

write_grub_defaults() {
  local background="$1"
  local defaults_file="/etc/default/grub"

  install -d /etc/default
  touch "$defaults_file"

  set_grub_var() {
    local key="$1"
    local value="$2"
    if grep -Eq "^${key}=" "$defaults_file"; then
      sed -i "s|^${key}=.*|${key}=${value}|g" "$defaults_file"
    else
      printf '%s=%s\n' "$key" "$value" >> "$defaults_file"
    fi
  }

  local theme_txt="/usr/share/grub/themes/umaos/theme.txt"

  set_grub_var GRUB_DISTRIBUTOR '"UmaOS"'
  set_grub_var GRUB_BACKGROUND "\"$background\""
  set_grub_var GRUB_GFXMODE 'auto'
  set_grub_var GRUB_GFXPAYLOAD_LINUX 'keep'
  set_grub_var GRUB_TIMEOUT_STYLE 'menu'
  set_grub_var GRUB_COLOR_NORMAL '"light-green/black"'
  set_grub_var GRUB_COLOR_HIGHLIGHT '"white/green"'

  # Apply the full custom GRUB theme if installed.
  if [[ -f "$theme_txt" ]]; then
    set_grub_var GRUB_THEME "\"$theme_txt\""
    log "Set GRUB_THEME=$theme_txt"
  fi

  log "Updated /etc/default/grub with UmaOS branding defaults"

  # Also write a drop-in for grub-mkconfig builds that source /etc/default/grub.d
  # (e.g., Debian-patched GRUB). Standard Arch grub-mkconfig does not use this
  # directory, but the drop-in is harmless and helps non-standard setups.
  install -d /etc/default/grub.d
  cat > /etc/default/grub.d/50-umaos-theme.cfg <<EOF
GRUB_DISTRIBUTOR="UmaOS"
GRUB_BACKGROUND="$background"
GRUB_GFXMODE=auto
GRUB_GFXPAYLOAD_LINUX=keep
GRUB_TIMEOUT_STYLE=menu
GRUB_COLOR_NORMAL="light-green/black"
GRUB_COLOR_HIGHLIGHT="white/green"
EOF

  if [[ -f "$theme_txt" ]]; then
    printf 'GRUB_THEME="%s"\n' "$theme_txt" >> /etc/default/grub.d/50-umaos-theme.cfg
  fi

  log "Wrote /etc/default/grub.d/50-umaos-theme.cfg (compatibility drop-in)"
}

rebuild_grub_config() {
  local cfg_target=""
  if [[ -d /boot/grub ]]; then
    cfg_target="/boot/grub/grub.cfg"
  elif [[ -d /boot/grub2 ]]; then
    cfg_target="/boot/grub2/grub.cfg"
  else
    log "GRUB directory not found; skipping grub.cfg regeneration."
    return 0
  fi

  if ! command -v grub-mkconfig >/dev/null 2>&1; then
    log "grub-mkconfig not found; skipping grub.cfg regeneration."
    return 0
  fi

  local grub_log
  grub_log="$(mktemp)"
  if grub-mkconfig -o "$cfg_target" >"$grub_log" 2>&1; then
    log "Regenerated $cfg_target with UmaOS branding."
    echo "Umazing!"
  else
    log "WARNING: Failed to regenerate $cfg_target. grub-mkconfig output:"
    cat "$grub_log" >&2
  fi
  rm -f "$grub_log"
}

install_theme_to_boot() {
  local src_theme="/usr/share/grub/themes/umaos"
  local dst_theme="/boot/grub/themes/umaos"

  if [[ ! -d "$src_theme" ]]; then
    log "No GRUB theme source at $src_theme; skipping theme install to /boot."
    return 0
  fi

  install -d "$dst_theme"
  cp -a "$src_theme"/* "$dst_theme/"
  log "Installed GRUB theme to $dst_theme"
}

main() {
  local source_bg=""
  local target_bg="/boot/grub/umaos-background.png"

  if ! source_bg="$(find_background_source)"; then
    log "No bundled background image found; skipping GRUB branding."
    exit 0
  fi

  if [[ ! -d /boot/grub ]]; then
    log "GRUB not detected in target; skipping GRUB branding."
    exit 0
  fi

  install -d /boot/grub
  cp -f "$source_bg" "$target_bg"
  log "Installed GRUB background: $target_bg"
  install_theme_to_boot
  write_grub_defaults "$target_bg"
  rebuild_grub_config
}

main "$@"
