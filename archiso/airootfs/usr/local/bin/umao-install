#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage: umao-install [--gui|--cli] [--autostart] [--help]

Default behavior:
  - launch Calamares GUI when available
  - if Calamares is unavailable or exits with an error, offer archinstall fallback

Options:
  --gui        Force Calamares GUI (exit non-zero on failure)
  --cli        Force archinstall TUI
  --autostart  Non-interactive mode for desktop autostart hook
  --help       Show this help text
USAGE
}

mode="auto"
autostart=0

while (($#)); do
  case "$1" in
    --gui)
      mode="gui"
      ;;
    --cli)
      mode="cli"
      ;;
    --autostart)
      autostart=1
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
  shift
done

run_cli() {
  if ! command -v archinstall >/dev/null 2>&1; then
    echo "archinstall not found in this live environment." >&2
    return 127
  fi

  echo "Launching archinstall..."
  local rc=0
  archinstall || rc=$?
  if ((rc == 0)); then
    echo "Umazing!"
  fi
  return $rc
}

run_gui() {
  if ! command -v calamares >/dev/null 2>&1; then
    echo "Calamares is not installed in this live environment." >&2
    return 127
  fi

  if [[ -z "${DISPLAY:-}" && -z "${WAYLAND_DISPLAY:-}" ]]; then
    echo "No graphical session detected. Run from KDE desktop, or use: umao-install --cli" >&2
    return 65
  fi

  if (($autostart == 0)); then
    cat <<'BANNER'
====================================
       UmaOS GUI Installer
====================================
BANNER
  fi

  if command -v umao-sync-calamares-config >/dev/null 2>&1; then
    if ! umao-sync-calamares-config; then
      echo "Warning: failed to sync UmaOS Calamares defaults; trying existing config." >&2
    fi
  fi

  if command -v umao-prepare-calamares >/dev/null 2>&1; then
    if ! umao-prepare-calamares; then
      echo "Warning: failed to refresh Calamares source paths; trying existing Calamares config." >&2
    fi
  fi

  if command -v localectl >/dev/null 2>&1; then
    x11_layout="$(localectl status 2>/dev/null | awk -F: '/X11 Layout/{gsub(/^[ \t]+/,"",$2); print $2; exit}' || true)"
    if [[ -z "${x11_layout:-}" || "${x11_layout}" == "custom" ]]; then
      echo "Warning: invalid X11 keyboard layout '${x11_layout:-<empty>}' detected, forcing 'us' for installer stability." >&2
      localectl --no-convert set-x11-keymap us pc105 "" "" >/dev/null 2>&1 || true
    fi
  fi

  local rc=0
  calamares || rc=$?
  if ((rc == 0)); then
    echo "Umazing!"
  fi
  return $rc
}

case "$mode" in
  cli)
    run_cli
    ;;
  gui)
    run_gui
    ;;
  auto)
    if [[ -z "${DISPLAY:-}" && -z "${WAYLAND_DISPLAY:-}" ]]; then
      if (($autostart == 1)); then
        echo "Autostart mode: no graphical session yet." >&2
        exit 1
      fi
      echo "No graphical session detected. Fall back to archinstall? [Y/n]"
      read -r answer
      answer=${answer:-Y}
      if [[ "$answer" =~ ^[Yy]$ ]]; then
        run_cli
      fi
      echo "Installer canceled."
      exit 0
    fi

    if command -v calamares >/dev/null 2>&1; then
      if run_gui; then
        exit 0
      fi
      echo "Calamares exited with an error." >&2
    fi

    if (($autostart == 1)); then
      echo "Autostart mode: Calamares unavailable or failed, skipping fallback." >&2
      exit 1
    fi

    echo "Calamares unavailable or failed. Fall back to archinstall? [Y/n]"
    read -r answer
    answer=${answer:-Y}
    if [[ "$answer" =~ ^[Yy]$ ]]; then
      run_cli
    fi
    echo "Installer canceled."
    ;;
esac
