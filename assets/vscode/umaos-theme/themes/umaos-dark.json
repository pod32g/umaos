{
    "name": "UmaOS Dark",
    "type": "dark",
    "colors": {
        "editor.background": "#132B4F",
        "editor.foreground": "#F8FBFF",
        "editor.selectionBackground": "#2F74CC80",
        "editor.lineHighlightBackground": "#1F4F9040",
        "editorCursor.foreground": "#FF91C0",
        "editorLineNumber.foreground": "#4A6A8A",
        "editorLineNumber.activeForeground": "#FF91C0",
        "activityBar.background": "#0D1E38",
        "activityBar.foreground": "#F8FBFF",
        "sideBar.background": "#0F2340",
        "sideBar.foreground": "#F8FBFF",
        "titleBar.activeBackground": "#1F4F90",
        "titleBar.activeForeground": "#F8FBFF",
        "statusBar.background": "#2F74CC",
        "statusBar.foreground": "#F8FBFF",
        "tab.activeBackground": "#132B4F",
        "tab.activeForeground": "#F8FBFF",
        "tab.inactiveBackground": "#0F2340",
        "tab.inactiveForeground": "#4A6A8A",
        "terminal.background": "#132B4F",
        "terminal.foreground": "#F8FBFF",
        "terminal.ansiBlue": "#2F74CC",
        "terminal.ansiMagenta": "#FF91C0",
        "terminal.ansiCyan": "#50C8C8",
        "terminal.ansiGreen": "#82C91E",
        "terminal.ansiYellow": "#FFC66D",
        "terminal.ansiRed": "#FF6B6B",
        "panel.background": "#0D1E38",
        "panel.border": "#1F4F90",
        "list.activeSelectionBackground": "#2F74CC",
        "list.activeSelectionForeground": "#F8FBFF",
        "list.hoverBackground": "#1F4F9060",
        "focusBorder": "#FF91C0",
        "input.background": "#1F4F90",
        "input.foreground": "#F8FBFF",
        "input.border": "#2F74CC",
        "button.background": "#2F74CC",
        "button.foreground": "#F8FBFF",
        "badge.background": "#FF91C0",
        "badge.foreground": "#132B4F"
    },
    "tokenColors": [
        { "scope": "comment", "settings": { "foreground": "#4A6A8A", "fontStyle": "italic" } },
        { "scope": "string", "settings": { "foreground": "#82C91E" } },
        { "scope": "keyword", "settings": { "foreground": "#FF91C0" } },
        { "scope": "entity.name.function", "settings": { "foreground": "#2F74CC" } },
        { "scope": "entity.name.type", "settings": { "foreground": "#FFD6E8" } },
        { "scope": "constant", "settings": { "foreground": "#FFC66D" } },
        { "scope": "variable", "settings": { "foreground": "#F8FBFF" } },
        { "scope": "support.function", "settings": { "foreground": "#50C8C8" } },
        { "scope": "storage", "settings": { "foreground": "#FF91C0" } },
        { "scope": "punctuation", "settings": { "foreground": "#F8FBFF" } },
        { "scope": "entity.name.tag", "settings": { "foreground": "#FF6B6B" } },
        { "scope": "entity.other.attribute-name", "settings": { "foreground": "#FFC66D" } },
        { "scope": "markup.heading", "settings": { "foreground": "#2F74CC", "fontStyle": "bold" } },
        { "scope": "markup.bold", "settings": { "fontStyle": "bold" } },
        { "scope": "markup.italic", "settings": { "fontStyle": "italic" } }
    ]
}
